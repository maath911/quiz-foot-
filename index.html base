  { q:"Quel pays a remporté le plus de Coupes du Monde ?", a:["Brésil","Allemagne","Italie","France"], correct:0 },
  { q:"Quel club est surnommé 'Les Merengues' ?", a:["Real Madrid","Atlético Madrid","FC Barcelone","Juventus"], correct:0 },
  { q:"Kylian Mbappé est de quelle nationalité ?", a:["Française","Espagnole","Belge","Portugaise"], correct:0 },
  { q:"Quelle est la couleur du maillot de l'équipe de France à domicile ?", a:["Bleu","Rouge","Blanc","Vert"], correct:0 },
