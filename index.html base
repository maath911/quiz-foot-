  { q:"Quelle équipe porte le surnom 'Les Diables Rouges' ?", a:["Belgique","Espagne","Portugal","Pays-Bas"], correct:0 },
  { q:"Combien de joueurs participent à un tir au but (péno) ?", a:["1 tireur + 1 gardien","2 tireurs","3 joueurs","Toute l'équipe"], correct:0 },
