<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Football Quiz ⚽</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #003087;
    --green-light: #0050b3;
    --green-glow: #4d9fff;
    --yellow: #f5c518;
    --red: #e63946;
    --white: #f0f0f0;
    --dark: #050d1a;
    --card: rgba(255,255,255,0.06);
    --psg-blue: #003087;
    --psg-red: #da291c;
    --psg-glow: #4d9fff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--dark); color: var(--white);
    font-family: 'Nunito', sans-serif; min-height: 100vh; overflow-x: hidden;
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(0,48,135,0.45) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(218,41,28,0.25) 0%, transparent 50%);
  }
  .field-lines {
    position: fixed; inset: 0; pointer-events: none; z-index: 0; opacity: 0.04;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 58px, #fff 58px, #fff 60px),
      repeating-linear-gradient(90deg, transparent, transparent 58px, #fff 58px, #fff 60px);
  }
  .screen { display: none; position: relative; z-index: 1; }
  .screen.active { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
  h1 {
    font-family: 'Bebas Neue', sans-serif; font-size: clamp(3rem, 10vw, 6rem);
    letter-spacing: 4px; color: var(--green-glow);
    text-shadow: 0 0 40px rgba(77,159,255,0.6), 0 4px 0 rgba(0,0,0,0.5); line-height: 1;
  }
  .subtitle { font-size: 1.1rem; opacity: 0.6; margin-top: 8px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; }
  .card {
    background: var(--card); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px; padding: 28px; backdrop-filter: blur(10px); width: 100%; max-width: 500px;
  }
  label { display: block; font-size: 0.8rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; opacity: 0.5; margin-bottom: 8px; }
  input[type="text"] {
    width: 100%; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px; padding: 12px 16px; color: #fff; font-family: 'Nunito', sans-serif;
    font-size: 1rem; font-weight: 700; outline: none; transition: border-color 0.2s, background 0.2s;
  }
  input[type="text"]:focus { border-color: var(--green-glow); background: rgba(77,159,255,0.08); }
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--green-light); border: none; border-radius: 12px;
    color: #fff; font-family: 'Nunito', sans-serif; font-size: 1rem; font-weight: 900;
    padding: 14px 28px; cursor: pointer; transition: all 0.2s; text-transform: uppercase; letter-spacing: 1px;
  }
  .btn:hover { background: var(--green-glow); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(77,159,255,0.4); }
  .btn:active { transform: translateY(0); }
  .btn.btn-big { font-size: 1.2rem; padding: 18px 40px; width: 100%; max-width: 320px; }
  .btn.btn-ghost { background: transparent; border: 2px solid rgba(255,255,255,0.2); }
  .btn.btn-ghost:hover { background: rgba(255,255,255,0.08); }
  .btn.btn-yellow { background: var(--yellow); color: #111; }
  .btn.btn-yellow:hover { filter: brightness(1.1); }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
  /* SETUP */
  #setup .card { margin-top: 16px; }
  .cnt-row { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
  .cnt-btn {
    flex: 1; min-width: 55px; background: rgba(255,255,255,0.06);
    border: 2px solid rgba(255,255,255,0.12); border-radius: 10px;
    color: #fff; font-family: 'Nunito', sans-serif; font-size: 1.1rem; font-weight: 900;
    padding: 12px; cursor: pointer; transition: all 0.2s;
  }
  .cnt-btn.selected { border-color: var(--green-glow); background: rgba(77,159,255,0.15); color: var(--green-glow); }
  .player-inputs { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
  .player-input-row { display: flex; align-items: center; gap: 10px; }
  .player-badge { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; font-weight: 900; flex-shrink: 0; }
  /* ROUNDS */
  #rounds-screen { gap: 20px; }
  #rounds-screen h2 { font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; letter-spacing: 3px; color: var(--green-glow); }
  .rounds-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; width: 100%; max-width: 420px; }
  .round-btn {
    background: rgba(255,255,255,0.06); border: 2px solid rgba(255,255,255,0.12);
    border-radius: 0px; color: #fff; font-family: 'Nunito', sans-serif;
    font-size: 1.1rem; font-weight: 900; padding: 18px 10px; cursor: pointer; transition: all 0.2s;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    aspect-ratio: 1 / 1;
  }
  .round-btn:hover { border-color: var(--green-glow); background: rgba(77,159,255,0.1); }
  .round-btn.selected { border-color: var(--green-glow); background: rgba(77,159,255,0.2); color: var(--green-glow); }
  .round-btn span { font-size: 0.7rem; opacity: 0.6; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
  /* DIFFICULTY */
  #difficulty { gap: 20px; }
  #difficulty h2 { font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; letter-spacing: 3px; color: var(--green-glow); }
  .current-player-badge {
    display: flex; align-items: center; gap: 12px;
    background: var(--card); border: 1px solid rgba(255,255,255,0.1); border-radius: 50px; padding: 10px 20px;
  }
  .diff-grid { display: grid; grid-template-columns: 1fr; gap: 14px; width: 100%; max-width: 400px; }
  .diff-card {
    background: var(--card); border: 2px solid rgba(255,255,255,0.1);
    border-radius: 14px; padding: 18px 22px; cursor: pointer;
    transition: all 0.2s; display: flex; align-items: center; justify-content: space-between;
  }
  .diff-card:hover { transform: translateX(6px); }
  .diff-card.easy:hover, .diff-card.easy.selected { border-color: #4d9fff; background: rgba(77,159,255,0.12); }
  .diff-card.medium:hover, .diff-card.medium.selected { border-color: var(--yellow); background: rgba(245,197,24,0.12); }
  .diff-card.hard:hover, .diff-card.hard.selected { border-color: var(--red); background: rgba(230,57,70,0.12); }
  .diff-name { font-size: 1.2rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; }
  .diff-pts { font-size: 0.85rem; opacity: 0.6; }
  /* QUIZ */
  #quiz { gap: 16px; justify-content: flex-start; padding-top: 30px; }
  .quiz-header { display: flex; align-items: center; justify-content: space-between; width: 100%; max-width: 640px; flex-wrap: wrap; gap: 10px; }
  .scoreboard { display: flex; gap: 8px; flex-wrap: wrap; }
  .score-chip {
    display: flex; align-items: center; gap: 6px;
    background: var(--card); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50px; padding: 6px 14px; font-size: 0.85rem; font-weight: 700; transition: all 0.3s;
  }
  .score-chip.active-player { border-color: var(--green-glow); background: rgba(77,159,255,0.15); box-shadow: 0 0 16px rgba(77,159,255,0.3); }
  .q-counter { font-size: 0.8rem; opacity: 0.5; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
  .turn-banner {
    width: 100%; max-width: 640px; display: flex; align-items: center; gap: 10px;
    padding: 12px 20px; border-radius: 12px; font-weight: 900; font-size: 1rem;
    background: rgba(77,159,255,0.1); border: 1px solid rgba(77,159,255,0.3); flex-wrap: wrap;
  }
  .diff-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
  }
  .diff-badge.easy { background: rgba(77,159,255,0.2); color: #4d9fff; }
  .diff-badge.medium { background: rgba(245,197,24,0.2); color: var(--yellow); }
  .diff-badge.hard { background: rgba(230,57,70,0.2); color: var(--red); }
  .question-card {
    width: 100%; max-width: 640px;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 18px; padding: 28px;
  }
  .question-text { font-size: 1.2rem; font-weight: 700; line-height: 1.5; margin-bottom: 20px; }
  .answers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; align-items: stretch; }
  @media(max-width:480px) { .answers-grid { grid-template-columns: 1fr; } }
  .answer-btn {
    background: rgba(255,255,255,0.06); border: 2px solid rgba(255,255,255,0.1);
    border-radius: 12px; color: #fff; font-family: 'Nunito', sans-serif;
    font-size: 0.9rem; font-weight: 700; padding: 14px 16px; cursor: pointer;
    transition: all 0.2s; text-align: left; display: flex; align-items: center; gap: 10px;
    width: 100%; min-height: 62px; word-break: break-word;
  }
  .answer-btn:hover:not(:disabled) { border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.1); }
  .answer-btn.correct { border-color: #4d9fff; background: rgba(77,159,255,0.2); animation: pop 0.3s ease; }
  .answer-btn.wrong { border-color: var(--red); background: rgba(230,57,70,0.15); }
  .answer-btn:disabled { cursor: default; }
  .answer-letter {
    width: 28px; height: 28px; border-radius: 6px; background: rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 900; flex-shrink: 0;
  }
  .timer-bar { width: 100%; height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; margin-bottom: 4px; }
  .timer-fill { height: 100%; background: var(--green-glow); border-radius: 2px; transition: width 1s linear; }
  /* RESULT */
  #result { gap: 20px; }
  #result h2 { font-family: 'Bebas Neue', sans-serif; font-size: 3rem; color: var(--yellow); letter-spacing: 3px; text-align:center; }
  .result-list { width: 100%; max-width: 400px; display: flex; flex-direction: column; gap: 8px; }
  .result-row {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--card); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 12px 18px;
  }
  .result-row.winner { border-color: var(--yellow); background: rgba(245,197,24,0.1); }
  @keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.04); } 100% { transform: scale(1); } }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .fade-in { animation: fadeIn 0.35s ease forwards; }
  .rounds-progress { font-size:0.8rem; opacity:0.5; font-weight:700; letter-spacing:1px; text-transform:uppercase; }
</style>
</head>
<body>
<div class="field-lines"></div>

<!-- HOME -->
<div id="home" class="screen active">
  <div style="text-align:center; animation: fadeIn 0.5s ease;">
    <div style="font-size:4rem;">⚽</div>
    <h1>FOOTBALL<br>QUIZ</h1>
    <p class="subtitle">Le quiz des champions</p>
    <div style="margin-top: 40px;">
      <button class="btn btn-big" onclick="showScreen('setup')">🚀 Commencer</button>
    </div>
    <p style="margin-top: 40px; font-size: 0.75rem; opacity: 0.35; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;">Jeu créé par Mathéo GONCALVES</p>
  </div>
</div>

<!-- SETUP PLAYERS -->
<div id="setup" class="screen">
  <div style="text-align:center; margin-bottom: 16px;" class="fade-in">
    <h1 style="font-size:3rem;">JOUEURS</h1>
    <p class="subtitle">Combien de joueurs ?</p>
  </div>
  <div class="card fade-in">
    <label>Nombre de joueurs</label>
    <div class="cnt-row" id="cntBtns">
      <button class="cnt-btn" onclick="setPlayerCount(1)">1</button>
      <button class="cnt-btn selected" onclick="setPlayerCount(2)">2</button>
      <button class="cnt-btn" onclick="setPlayerCount(3)">3</button>
      <button class="cnt-btn" onclick="setPlayerCount(4)">4</button>
    </div>
    <label>Noms des joueurs</label>
    <div class="player-inputs" id="playerInputs"></div>
    <button class="btn" style="width:100%" onclick="goToRounds()">Suivant →</button>
  </div>
  <button class="btn btn-ghost" style="margin-top:12px;" onclick="showScreen('home')">← Retour</button>
</div>

<!-- ROUNDS SELECTION -->
<div id="rounds-screen" class="screen">
  <h2 class="fade-in">NOMBRE DE TOURS</h2>
  <p class="fade-in" style="opacity:0.5; font-size:0.9rem; margin-top:-10px; letter-spacing:1px;">Par joueur</p>
  <div class="rounds-grid fade-in">
    <button class="round-btn" onclick="setRounds(3)">3<span>Tours</span></button>
    <button class="round-btn selected" onclick="setRounds(5)">5<span>Tours</span></button>
    <button class="round-btn" onclick="setRounds(10)">10<span>Tours</span></button>
    <button class="round-btn" onclick="setRounds(15)">15<span>Tours</span></button>
  </div>
  <div class="fade-in" style="text-align:center; opacity:0.5; font-size:0.85rem; margin-top:4px;" id="roundsInfo"></div>
  <div style="display:flex; gap:12px; margin-top:8px;" class="fade-in">
    <button class="btn btn-ghost" onclick="showScreen('setup')">← Retour</button>
    <button class="btn" onclick="startGame()">✅ Lancer la partie !</button>
  </div>
</div>

<!-- DIFFICULTY -->
<div id="difficulty" class="screen">
  <div class="current-player-badge fade-in" id="diffPlayerBadge"></div>
  <h2 class="fade-in" style="font-family:'Bebas Neue',sans-serif; font-size:2.5rem; letter-spacing:3px; color:var(--green-glow);">CHOIX DE DIFFICULTÉ</h2>
  <div class="rounds-progress fade-in" id="roundsProgress"></div>
  <div class="diff-grid fade-in">
    <div class="diff-card easy" onclick="chooseDifficulty('easy')">
      <div>
        <div class="diff-name" style="color:#4d9fff;">🔵 Facile</div>
        <div class="diff-pts">1 point par bonne réponse</div>
      </div>
    </div>
    <div class="diff-card medium" onclick="chooseDifficulty('medium')">
      <div>
        <div class="diff-name" style="color:#f5c518;">🟡 Moyen</div>
        <div class="diff-pts">2 points par bonne réponse</div>
      </div>
    </div>
    <div class="diff-card hard" onclick="chooseDifficulty('hard')">
      <div>
        <div class="diff-name" style="color:#e63946;">🔴 Difficile</div>
        <div class="diff-pts">3 points par bonne réponse</div>
      </div>
    </div>
  </div>
</div>

<!-- QUIZ -->
<div id="quiz" class="screen">
  <div class="quiz-header fade-in">
    <div class="scoreboard" id="scoreboard"></div>
    <div class="q-counter" id="qCounter"></div>
  </div>
  <div class="turn-banner fade-in" id="turnBanner"></div>
  <div class="question-card fade-in">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
      <span class="diff-badge" id="diffBadge"></span>
      <span id="timerText" style="font-size:0.85rem; opacity:0.6; font-weight:700;"></span>
    </div>
    <div class="timer-bar"><div class="timer-fill" id="timerFill" style="width:100%"></div></div>
    <div class="question-text" id="questionText"></div>
    <div class="answers-grid" id="answersGrid"></div>
  </div>
  <div id="feedbackArea" style="margin-top:8px; font-size:1rem; font-weight:700; min-height:30px; text-align:center;"></div>
  <button class="btn" id="nextBtn" style="display:none; margin-top:8px;" onclick="nextTurn()">Tour suivant ➡️</button>
</div>

<!-- RESULT -->
<div id="result" class="screen">
  <div style="font-size:3rem;" class="fade-in">🏆</div>
  <h2 class="fade-in" id="resultTitle">FIN DU QUIZ !</h2>
  <div class="result-list fade-in" id="resultList"></div>
  <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center; margin-top:20px;" class="fade-in">
    <button class="btn btn-yellow" onclick="restartGame()">🔄 Rejouer</button>
    <button class="btn btn-ghost" onclick="showScreen('home')">🏠 Accueil</button>
  </div>
</div>

<script>
const COLORS = ['#4d9fff','#da291c','#f5c518','#ffffff'];
const AVATARS = ['⚽','🥅','👟','🏆'];
const DIFF_LABELS = { easy: 'Facile', medium: 'Moyen', hard: 'Difficile' };
const DIFF_PTS = { easy: 1, medium: 2, hard: 3 };
const LETTERS = ['A','B','C','D'];

const QUESTIONS = {
easy: [
  // === RÈGLES DE BASE ===
  { q:"Combien de joueurs y a-t-il dans une équipe de football sur le terrain ?", a:["11","10","12","9"], correct:0 },
  { q:"Quel pays a remporté la Coupe du Monde 2018 ?", a:["France","Croatie","Allemagne","Brésil"], correct:0 },
  { q:"Quelle est la durée réglementaire d'un match de football ?", a:["90 minutes","80 minutes","100 minutes","120 minutes"], correct:0 },
  { q:"Quel club est surnommé 'Les Blaugrana' ?", a:["FC Barcelone","Real Madrid","PSG","Bayern Munich"], correct:0 },
  { q:"Dans quel pays joue le club de Manchester United ?", a:["Angleterre","Écosse","Irlande","Pays de Galles"], correct:0 },
  { q:"Qui est surnommé 'La Pulga' (La Puce) ?", a:["Lionel Messi","Cristiano Ronaldo","Neymar","Mbappé"], correct:0 },
