let players = [];
let currentPlayerIdx = 0;
let currentDifficulty = null;
let selectedRounds = 5;
let usedQuestions = { easy: new Set(), medium: new Set(), hard: new Set() };
let questionPool = { easy: [], medium: [], hard: [] };
let currentRound = 0; // total turns done
let totalTurns = 0;
let timerInterval = null;
let timerValue = 20;

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function setPlayerCount(n) {
  document.querySelectorAll('.cnt-btn').forEach((b,i) => b.classList.toggle('selected', i+1===n));
  const container = document.getElementById('playerInputs');
  container.innerHTML = '';
  for(let i = 0; i < n; i++) {
    container.innerHTML += `
      <div class="player-input-row">
        <div class="player-badge" style="background:${COLORS[i]}20;color:${COLORS[i]};border:2px solid ${COLORS[i]};">${AVATARS[i]}</div>
        <input type="text" id="pname${i}" placeholder="Joueur ${i+1}" value="${players[i]?.name||''}">
      </div>`;
  }
  updateRoundsInfo();
}

function goToRounds() {
  const n = [...document.querySelectorAll('.cnt-btn')].findIndex(b => b.classList.contains('selected')) + 1;
  players = [];
  for(let i = 0; i < n; i++) {
    const v = document.getElementById('pname'+i)?.value.trim() || `Joueur ${i+1}`;
    players.push({ name: v, score: 0, color: COLORS[i], avatar: AVATARS[i] });
  }
  updateRoundsInfo();
  showScreen('rounds-screen');
}

function setRounds(n) {
  selectedRounds = n;
  document.querySelectorAll('.round-btn').forEach(b => b.classList.remove('selected'));
  event.currentTarget.classList.add('selected');
  updateRoundsInfo();
}

function updateRoundsInfo() {
  const n = players.length || ([...document.querySelectorAll('.cnt-btn')].findIndex(b => b.classList.contains('selected')) + 1);
  const el = document.getElementById('roundsInfo');
  if(el) el.textContent = `Soit ${selectedRounds * n} questions au total (${n} joueur${n>1?'s':''} × ${selectedRounds} tours)`;
}

function startGame() {
  totalTurns = selectedRounds * players.length;
  currentRound = 0;
  currentPlayerIdx = 0;
  players.forEach(p => p.score = 0);
  usedQuestions = { easy: new Set(), medium: new Set(), hard: new Set() };
  questionPool = {
    easy: shuffle([...Array(QUESTIONS.easy.length).keys()]),
    medium: shuffle([...Array(QUESTIONS.medium.length).keys()]),
    hard: shuffle([...Array(QUESTIONS.hard.length).keys()])
  };
  showDifficultyScreen();
}

function shuffle(arr) {
  for(let i = arr.length-1; i > 0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [arr[i],arr[j]] = [arr[j],arr[i]];
  }
  return arr;
}

function showDifficultyScreen() {
  if(currentRound >= totalTurns) { showResult(); return; }
  const p = players[currentPlayerIdx];
  const roundNum = Math.floor(currentRound / players.length) + 1;
  document.getElementById('diffPlayerBadge').innerHTML = `
    <div style="width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:${p.color}20;color:${p.color};border:2px solid ${p.color};">${p.avatar}</div>
    <span style="font-weight:900;font-size:1.1rem;">${p.name}</span>
    <span style="opacity:0.5;font-size:0.85rem;">— Choisis ta difficulté</span>
  `;
  document.getElementById('roundsProgress').textContent = `Tour ${roundNum} / ${selectedRounds}  •  Question ${currentRound+1} / ${totalTurns}`;
  showScreen('difficulty');
}

function chooseDifficulty(diff) {
  currentDifficulty = diff;
  if(questionPool[diff].length === 0) {
    // Ran out — reshuffle excluding none (all used, allow repeats only after full cycle)
    questionPool[diff] = shuffle([...Array(QUESTIONS[diff].length).keys()]);
    usedQuestions[diff].clear();
  }
  showQuestion();
}

function showQuestion() {
  const idx = questionPool[currentDifficulty].pop();
  const q = QUESTIONS[currentDifficulty][idx];
  const p = players[currentPlayerIdx];
  showScreen('quiz');

  document.getElementById('scoreboard').innerHTML = players.map((pl,i) =>
    `<div class="score-chip ${i===currentPlayerIdx?'active-player':''}">
      <span>${pl.avatar}</span>
      <span style="color:${pl.color}">${pl.name}</span>
      <span style="font-size:0.9rem;color:var(--green-glow);">${pl.score}pts</span>
    </div>`).join('');

  const roundNum = Math.floor(currentRound / players.length) + 1;
  document.getElementById('qCounter').textContent = `Tour ${roundNum}/${selectedRounds} • Q${currentRound+1}/${totalTurns}`;

  document.getElementById('turnBanner').innerHTML = `
    <span>${p.avatar}</span>
    <span>Tour de <strong style="color:${p.color}">${p.name}</strong></span>
    <span class="diff-badge ${currentDifficulty}">${DIFF_LABELS[currentDifficulty]} +${DIFF_PTS[currentDifficulty]}pt</span>
  `;

  const badge = document.getElementById('diffBadge');
  badge.className = `diff-badge ${currentDifficulty}`;
  badge.textContent = DIFF_LABELS[currentDifficulty];
  document.getElementById('questionText').textContent = q.q;

  const shuffled = shuffleAnswers(q.a, q.correct);
  document.getElementById('answersGrid').innerHTML = shuffled.map((ans, i) =>
    `<button class="answer-btn" onclick="checkAnswer(${i}, ${shuffled.correctIdx}, this)">
      <span class="answer-letter">${LETTERS[i]}</span>${ans}
    </button>`).join('');

  document.getElementById('feedbackArea').textContent = '';
  document.getElementById('nextBtn').style.display = 'none';
  startTimer();
}

function shuffleAnswers(answers, correctIdx) {
  const pairs = answers.map((a,i) => ({a, isCorrect: i===correctIdx}));
  for(let i = pairs.length-1; i>0; i--){
    const j = Math.floor(Math.random()*(i+1));
    [pairs[i],pairs[j]] = [pairs[j],pairs[i]];
  }
  const result = pairs.map(p => p.a);
  result.correctIdx = pairs.findIndex(p => p.isCorrect);
  return result;
}

// Normalize text lengths so no answer is visually "longer" and thus more noticeable
function normalizeAnswerLengths(answers) {
  // Find the max length of any answer
  const maxLen = Math.max(...answers.map(a => a.length));
  // Only pad if the spread between min and max is large (>30 chars gap)
  const minLen = Math.min(...answers.map(a => a.length));
  if (maxLen - minLen < 25) return answers; // fine as-is
  // For visual balance, we use a trick: add an invisible zero-width joiner to short answers
  // Actually — just don't. The real fix is CSS equal height + wrapping.
  return answers;
}

const DIFF_TIME = { easy: 10, medium: 20, hard: 30 };

function startTimer() {
  clearInterval(timerInterval);
  const maxTime = DIFF_TIME[currentDifficulty] || 20;
  timerValue = maxTime;
  document.getElementById('timerFill').style.width = '100%';
  document.getElementById('timerFill').style.background = 'var(--green-glow)';
  document.getElementById('timerText').textContent = `⏱ ${timerValue}s`;
  timerInterval = setInterval(() => {
    timerValue--;
    const pct = (timerValue / maxTime) * 100;
    document.getElementById('timerFill').style.width = pct + '%';
    document.getElementById('timerFill').style.background = pct > 50 ? 'var(--green-glow)' : pct > 25 ? 'var(--yellow)' : 'var(--red)';
    document.getElementById('timerText').textContent = `⏱ ${timerValue}s`;
    if(timerValue <= 0) { clearInterval(timerInterval); timeOut(); }
  }, 1000);
}

function timeOut() {
  document.querySelectorAll('.answer-btn').forEach(b => b.disabled = true);
  document.getElementById('feedbackArea').innerHTML = `<span style="color:var(--red);">⏰ Temps écoulé ! Aucun point.</span>`;
  document.getElementById('nextBtn').style.display = 'inline-flex';
}

function checkAnswer(chosen, correct, btn) {
  clearInterval(timerInterval);
  const btns = document.querySelectorAll('.answer-btn');
  btns.forEach(b => b.disabled = true);
  btns[correct].classList.add('correct');
  if(chosen === correct) {
    const pts = DIFF_PTS[currentDifficulty];
    players[currentPlayerIdx].score += pts;
    btn.classList.add('correct');
    document.getElementById('feedbackArea').innerHTML = `<span style="color:#4d9fff;">✅ Correct ! +${pts} point${pts>1?'s':''} 🎉</span>`;
  } else {
    btn.classList.add('wrong');
    document.getElementById('feedbackArea').innerHTML = `<span style="color:var(--red);">❌ Raté ! Bonne réponse : <strong>${btns[correct].textContent.slice(1)}</strong></span>`;
  }
  document.getElementById('nextBtn').style.display = 'inline-flex';
}

function nextTurn() {
  currentRound++;
  currentPlayerIdx = (currentPlayerIdx + 1) % players.length;
  if(currentRound >= totalTurns) showResult();
  else showDifficultyScreen();
}

function showResult() {
  showScreen('result');
  const sorted = [...players].sort((a,b) => b.score - a.score);
  document.getElementById('resultTitle').textContent = `🏆 ${sorted[0].name} Gagne !`;
  const medals = ['🥇','🥈','🥉','4️⃣'];
  document.getElementById('resultList').innerHTML = sorted.map((p,i) => `
    <div class="result-row ${i===0?'winner':''}">
      <div style="display:flex;align-items:center;gap:12px;">
        <span style="font-size:1.5rem;">${medals[i]}</span>
        <span style="font-size:1.3rem;">${p.avatar}</span>
        <span style="font-weight:900;color:${p.color};">${p.name}</span>
      </div>
      <span style="font-family:'Bebas Neue';font-size:1.8rem;color:var(--green-glow);">${p.score} pts</span>
    </div>`).join('');
}

function restartGame() {
  players.forEach(p => p.score = 0);
  currentRound = 0;
  currentPlayerIdx = 0;
  usedQuestions = { easy: new Set(), medium: new Set(), hard: new Set() };
  questionPool = {
    easy: shuffle([...Array(QUESTIONS.easy.length).keys()]),
    medium: shuffle([...Array(QUESTIONS.medium.length).keys()]),
    hard: shuffle([...Array(QUESTIONS.hard.length).keys()])
  };
  showDifficultyScreen();
}

// Init
setPlayerCount(2);
updateRoundsInfo();
</script>
