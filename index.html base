  { q:"Quelle est la surface de réparation dans le football ?", a:["La surface où le gardien peut utiliser ses mains","La surface centrale délimitant le jeu en attaque","La zone de corner dans les angles du terrain","Le grand rond central au milieu du terrain"], correct:0 },
  { q:"Qui est l'entraîneur de l'équipe de France championne du monde 2018 ?", a:["Didier Deschamps","Laurent Blanc","Raymond Domenech","Zinédine Zidane"], correct:0 },
  { q:"Quel pays a remporté l'Euro 2021 ?", a:["Italie","Angleterre","Espagne","France"], correct:0 },
  { q:"Combien de joueurs forment la ligne défensive dans un 4-4-2 ?", a:["4","3","5","2"], correct:0 },
